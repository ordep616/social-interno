{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "message-created.schema.json",
  "title": "MessageCreatedEvent",
  "type": "object",
  "required": ["eventId", "type", "version", "occurredAt", "conversationId", "data"],
  "properties": {
    "eventId": { "type": "string" },
    "type": { "const": "message.created" },
    "version": { "const": 1 },
    "occurredAt": { "type": "string", "format": "date-time" },
    "conversationId": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["message"],
      "properties": { "message": { "type": "object" } },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
